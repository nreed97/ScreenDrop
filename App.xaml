<Application x:Class="ScreenDrop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ContextMenu x:Key="TrayMenu">
                <MenuItem Header="Take Screenshot" Click="TakeScreenshot_Click"/>
                <MenuItem Header="Select Region" Click="SelectRegion_Click"/>
                <MenuItem Header="Upload File..." Click="UploadFile_Click"/>
                <MenuItem Header="Upload Text/Paste..." Click="UploadPaste_Click"/>
                <Separator/>
                <MenuItem Header="Settings" Click="Settings_Click"/>
                <Separator/>
                <MenuItem Header="Exit" Click="Exit_Click"/>
            </ContextMenu>
        </ResourceDictionary>
    </Application.Resources>
</Application>
