<Window x:Class="ScreenDrop.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ScreenDrop.ViewModels"
        xmlns:conv="clr-namespace:ScreenDrop.Converters"
        Title="ScreenDrop Settings"
        Width="900" Height="650"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#F5F5F5">
    <Window.Resources>
        <conv:ByteArrayToImageConverter x:Key="ByteArrayToImageConverter"/>
        <conv:FileSizeConverter x:Key="FileSizeConverter"/>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TabControl Grid.Row="0">
            <!-- General Tab -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <TextBlock Text="DigitalOcean Spaces Configuration"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Access Key" Margin="0,0,0,5"/>
                            <TextBox x:Name="AccessKeyBox" Text="{Binding AccessKey, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="8"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Secret Key" Margin="0,0,0,5"/>
                            <PasswordBox x:Name="SecretKeyBox" Padding="8"
                                         PasswordChanged="SecretKeyBox_PasswordChanged"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Bucket Name" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding BucketName, UpdateSourceTrigger=PropertyChanged}" Padding="8"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Region" Margin="0,0,0,5"/>
                            <ComboBox ItemsSource="{Binding AvailableRegions}" 
                                      SelectedItem="{Binding Region}" Padding="8"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Custom Domain (optional)" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding CustomDomain, UpdateSourceTrigger=PropertyChanged}" Padding="8"/>
                        </StackPanel>

                        <TextBlock Text="Upload Folders"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,15,0,10"/>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Screenshot Folder" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding ScreenshotFolder, UpdateSourceTrigger=PropertyChanged}" Padding="8"/>
                            <TextBlock Text="Folder name for screenshots (e.g., caps, screenshots)" 
                                       Foreground="Gray" FontSize="11" Margin="0,3,0,0"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="File Upload Folder" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding FileFolder, UpdateSourceTrigger=PropertyChanged}" Padding="8"/>
                            <TextBlock Text="Folder name for uploaded files (e.g., files, uploads)" 
                                       Foreground="Gray" FontSize="11" Margin="0,3,0,0"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Paste Folder" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding PasteFolder, UpdateSourceTrigger=PropertyChanged}" Padding="8"/>
                            <TextBlock Text="Folder name for text pastes (e.g., pastes, code)" 
                                       Foreground="Gray" FontSize="11" Margin="0,3,0,0"/>
                        </StackPanel>

                        <TextBlock Text="Filename Templates"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,15,0,10"/>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Screenshot Filename Template" Margin="0,0,0,5"/>
                            <TextBox x:Name="ScreenshotTemplateBox" 
                                     Text="{Binding ScreenshotFilenameTemplate, UpdateSourceTrigger=PropertyChanged}" 
                                     Padding="8"
                                     TextChanged="TemplateBox_TextChanged"/>
                            <TextBlock x:Name="ScreenshotTemplateExample" 
                                       Foreground="Gray" FontSize="11" Margin="0,3,0,0"
                                       Text="Example: 20260227_143052_a3f8d9e2.png"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="File Upload Filename Template" Margin="0,0,0,5"/>
                            <TextBox x:Name="FileTemplateBox" 
                                     Text="{Binding FileFilenameTemplate, UpdateSourceTrigger=PropertyChanged}" 
                                     Padding="8"
                                     TextChanged="TemplateBox_TextChanged"/>
                            <TextBlock x:Name="FileTemplateExample" 
                                       Foreground="Gray" FontSize="11" Margin="0,3,0,0"
                                       Text="Example: 20260227_143052_a3f8d9e2.pdf"/>
                        </StackPanel>

                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,10" Foreground="#666" FontSize="11">
                            Available variables: {{date}} = 20260227, {{time}} = 143052, {{timestamp}} = 20260227_143052, {{random}} = 8 chars, {{type}} = screenshot/file
                        </TextBlock>

                        <CheckBox Content="Use Original Filename (ignore templates when uploading files)"
                                  IsChecked="{Binding UseOriginalFilename}"
                                  Margin="0,0,0,10"/>

                        <TextBlock Text="History Management"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,15,0,10"/>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Delete History Older Than (Days)" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding HistoryRetentionDays, UpdateSourceTrigger=PropertyChanged}" 
                                     Padding="8" Width="100" HorizontalAlignment="Left"/>
                            <TextBlock Text="Set to 0 to keep history forever" 
                                       Foreground="Gray" FontSize="11" Margin="0,3,0,0"/>
                        </StackPanel>

                        <CheckBox Content="Enable Clipboard Monitoring"
                                  IsChecked="{Binding ClipboardMonitoringEnabled}"
                                  Margin="0,10,0,10"/>

                        <Button Content="Test Connection" Command="{Binding TestConnectionCommand}"
                                Width="150" HorizontalAlignment="Left" Margin="0,10,0,0" Padding="10,5"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- Keybindings Tab -->
            <TabItem Header="Keybindings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <TextBlock Text="Global Hotkeys"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>

                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Full Screen Capture" Margin="0,0,0,5"/>
                            <TextBox x:Name="FullScreenHotkeyBox" 
                                     Text="{Binding FullScreenHotkey, UpdateSourceTrigger=PropertyChanged}" 
                                     Padding="8" IsReadOnly="True" Background="#F0F0F0"
                                     PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                            <TextBlock Text="Click in box and press desired key combination" 
                                       Foreground="Gray" FontSize="11" Margin="0,3,0,0"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Region Capture" Margin="0,0,0,5"/>
                            <TextBox x:Name="RegionHotkeyBox" 
                                     Text="{Binding RegionHotkey, UpdateSourceTrigger=PropertyChanged}" 
                                     Padding="8" IsReadOnly="True" Background="#F0F0F0"
                                     PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                            <TextBlock Text="Click in box and press desired key combination" 
                                       Foreground="Gray" FontSize="11" Margin="0,3,0,0"/>
                        </StackPanel>

                        <TextBlock TextWrapping="Wrap" Margin="0,10,0,0" Foreground="#666">
                            <Run Text="Supported modifiers: Ctrl, Shift, Alt"/>
                            <LineBreak/>
                            <Run Text="Example: Ctrl+Shift+S, Alt+P, Ctrl+Alt+X"/>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <!-- History Tab -->
            <TabItem Header="History">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Upload History"
                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBox x:Name="SearchBox" 
                                 Width="250" Padding="6" Margin="0,0,10,0"
                                 TextChanged="SearchBox_TextChanged"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="Refresh" Command="{Binding RefreshHistoryCommand}" 
                                Padding="10,5" Margin="0,0,10,0"/>
                        <Button Content="Clear History" Command="{Binding ClearHistoryCommand}" 
                                Padding="10,5" Background="#DC3545" Foreground="White"/>
                    </StackPanel>

                    <DataGrid Grid.Row="2" x:Name="HistoryDataGrid"
                              ItemsSource="{Binding UploadHistory}"
                              SelectedItem="{Binding SelectedRecord}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              CanUserAddRows="False"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              AlternatingRowBackground="#F9F9F9">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Preview" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Image Width="60" Height="60" Margin="5"
                                               Source="{Binding ThumbnailData, Converter={StaticResource ByteArrayToImageConverter}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Filename" Binding="{Binding FileName}" Width="250"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding UploadType}" Width="90"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding UploadDate, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="130"/>
                            <DataGridTextColumn Header="Size" Binding="{Binding FileSize, Converter={StaticResource FileSizeConverter}}" Width="80"/>
                            <DataGridTemplateColumn Header="Actions" Width="280" MinWidth="280">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Copy URL" 
                                                    Command="{Binding DataContext.CopyUrlCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="5,2" Margin="2"/>
                                            <Button Content="Open" 
                                                    Command="{Binding DataContext.OpenUrlCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="5,2" Margin="2"/>
                                            <Button Content="Delete" 
                                                    Command="{Binding DataContext.DeleteRecordCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Background="#DC3545" Foreground="White"
                                                    Padding="5,2" Margin="2"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="3" Text="{Binding HistoryStatusMessage}" 
                               Margin="0,10,0,0" FontSize="12" Foreground="#666"/>
                </Grid>
            </TabItem>
            
            <!-- Help Tab -->
            <TabItem Header="Help">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <TextBlock Text="ScreenDrop Help"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>

                        <TextBlock Text="Quick Start" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,15">
                            1. Configure your DigitalOcean Spaces credentials in the General tab<LineBreak/>
                            2. Set your preferred hotkeys in the Keybindings tab<LineBreak/>
                            3. Click Save &amp; Close to start using ScreenDrop
                        </TextBlock>

                        <TextBlock Text="Features" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,15">
                            • Full screen capture with customizable hotkey<LineBreak/>
                            • Region selection capture with customizable hotkey<LineBreak/>
                            • Upload any file from your PC via tray menu<LineBreak/>
                            • Pastebin-like text/code upload with syntax highlighting<LineBreak/>
                            • Automatic upload to DigitalOcean Spaces with public URLs<LineBreak/>
                            • Upload history tracking with SQLite database<LineBreak/>
                            • Customizable filename templates with variables<LineBreak/>
                            • Option to preserve original filenames<LineBreak/>
                            • Configurable upload folders for screenshots, files, and pastes<LineBreak/>
                            • Delete files directly from DigitalOcean Spaces<LineBreak/>
                            • Automatic cleanup of old history records<LineBreak/>
                            • Upload status indicator (icon changes color)<LineBreak/>
                            • Optional clipboard monitoring for auto-upload<LineBreak/>
                            • System tray integration with right-click menu
                        </TextBlock>

                        <TextBlock Text="Usage" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,15">
                            • Press your full screen hotkey (default: Ctrl+Shift+S) to capture entire screen<LineBreak/>
                            • Press your region hotkey (default: Ctrl+Shift+R) to select a region<LineBreak/>
                            • Right-click tray icon → Upload File... to upload any file<LineBreak/>
                            • Right-click tray icon → Upload Text/Paste... to share text or code<LineBreak/>
                            • Double-click tray icon for quick full screen capture<LineBreak/>
                            • Right-click tray icon for menu options<LineBreak/>
                            • Screenshots go to your configured screenshot folder (default: caps)<LineBreak/>
                            • Uploaded files go to your configured file folder (default: files)<LineBreak/>
                            • Text pastes go to your configured paste folder (default: pastes)
                        </TextBlock>

                        <TextBlock Text="Clipboard Monitoring" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,15">
                            When enabled in General settings, ScreenDrop automatically monitors your clipboard:<LineBreak/>
                            <LineBreak/>
                            • Detects when you copy an image (e.g., from Snipping Tool, Paint, browser)<LineBreak/>
                            • Automatically uploads the image to your screenshot folder<LineBreak/>
                            • Copies the public URL to your clipboard (replaces the image)<LineBreak/>
                            • Also works when you copy image files in File Explorer<LineBreak/>
                            <LineBreak/>
                            This is perfect for quick sharing - just copy any image and get an instant URL!
                        </TextBlock>

                        <TextBlock Text="Text/Paste Uploads" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,15">
                            Share text content like error logs, code snippets, or configuration files:<LineBreak/>
                            <LineBreak/>
                            • Right-click tray icon → Upload Text/Paste...<LineBreak/>
                            • Paste or type your content in the dialog<LineBreak/>
                            • Optionally add a title for identification<LineBreak/>
                            • Enable syntax highlighting for code (auto-detects language)<LineBreak/>
                            • Toggle line numbers on/off<LineBreak/>
                            • Content is uploaded as an HTML page viewable in any browser<LineBreak/>
                            • Viewers can copy the content or download as raw text<LineBreak/>
                            <LineBreak/>
                            Perfect for sharing error logs with developers or code snippets with colleagues!
                        </TextBlock>

                        <TextBlock Text="Filename Templates" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,15">
                            Customize how your files are named using template variables:<LineBreak/>
                            <LineBreak/>
                            • {date} - Current date (e.g., 2026-02-28)<LineBreak/>
                            • {time} - Current time (e.g., 14-30-45)<LineBreak/>
                            • {timestamp} - Unix timestamp (e.g., 1798675845)<LineBreak/>
                            • {random} - Random 6-character alphanumeric string<LineBreak/>
                            • {type} - File type: "screenshot" or "file"<LineBreak/>
                            <LineBreak/>
                            Example: "cap_{date}_{random}" becomes "cap_2026-02-28_a3f9k2.png"<LineBreak/>
                            <LineBreak/>
                            Enable "Use Original Filename" to keep the original name instead of applying templates.
                        </TextBlock>

                        <TextBlock Text="History Management" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,15">
                            ScreenDrop tracks all your uploads in a local SQLite database:<LineBreak/>
                            <LineBreak/>
                            • View all uploads in the History tab<LineBreak/>
                            • Search by filename or URL<LineBreak/>
                            • Copy URL, open in browser, or delete from cloud storage<LineBreak/>
                            • Thumbnails are generated automatically for images<LineBreak/>
                            • File sizes are displayed in human-readable format<LineBreak/>
                            <LineBreak/>
                            <Bold>Auto-Deletion:</Bold> Configure how long to keep history records:<LineBreak/>
                            • Set to 0 days to keep history forever<LineBreak/>
                            • Set to 1+ days to automatically delete old records<LineBreak/>
                            • Cleanup runs when the app starts<LineBreak/>
                            • Only deletes database records, NOT files from Spaces
                        </TextBlock>

                        <TextBlock Text="Upload Status Indicator" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,15">
                            The system tray icon changes color to show upload status:<LineBreak/>
                            <LineBreak/>
                            • Blue icon - Idle, ready to capture<LineBreak/>
                            • Orange icon - Upload in progress<LineBreak/>
                            <LineBreak/>
                            After upload completes, the URL is automatically copied to your clipboard and a notification appears.
                        </TextBlock>

                        <TextBlock Text="File Storage Locations" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,15">
                            All settings and data are stored in your AppData folder:<LineBreak/>
                            <LineBreak/>
                            • Settings: %APPDATA%\ScreenDrop\settings.json<LineBreak/>
                            • Database: %APPDATA%\ScreenDrop\uploads.db<LineBreak/>
                            <LineBreak/>
                            This allows you to share the ScreenDrop.exe file without exposing your credentials.<LineBreak/>
                            Each user will have their own settings and history.
                        </TextBlock>

                        <TextBlock Text="Deleting from DigitalOcean Spaces" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,15">
                            You can delete files directly from cloud storage:<LineBreak/>
                            <LineBreak/>
                            1. Go to the History tab<LineBreak/>
                            2. Find the file you want to delete<LineBreak/>
                            3. Click "Delete from Spaces"<LineBreak/>
                            4. Confirm the deletion<LineBreak/>
                            <LineBreak/>
                            This permanently removes the file from DigitalOcean Spaces and deletes the history record.
                        </TextBlock>

                        <TextBlock Text="DigitalOcean Spaces Setup" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,15">
                            1. Create a Space in your DigitalOcean account<LineBreak/>
                            2. Generate API keys (Access Key and Secret Key)<LineBreak/>
                            3. Note your Space name and region<LineBreak/>
                            4. Optionally configure a custom domain (CDN)<LineBreak/>
                            5. Ensure your Space has public read permissions
                        </TextBlock>

                        <TextBlock Text="About" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBlock TextWrapping="Wrap">
                            ScreenDrop v1.0<LineBreak/>
                            A simple screenshot tool with automatic cloud upload
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}"
                   Foreground="Green" Margin="0,10,0,10" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save &amp; Close" Click="SaveAndClose_Click"
                    Width="120" Padding="10,5" Background="#0078D4" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
